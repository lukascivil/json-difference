{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "@nx/eslint:lint": {
      "dependsOn": ["^lint"],
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs", "{workspaceRoot}/tools/eslint-rules/**/*"]
    }
  },
  "defaultBase": "master",
  "packageManager": "yarn",
  "analytics": false
}
