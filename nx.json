{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "@nx/eslint:lint": {
      "dependsOn": ["^lint"],
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs", "{workspaceRoot}/tools/eslint-rules/**/*"]
    }
  },
  "defaultBase": "master",
  "packageManager": "yarn",
  "analytics": false,
  "release": {
    "projects": ["json-difference", "json-difference-cli", "playground", "mcp-json-diff"],
    "projectsRelationship": "independent",
    "releaseTagPattern": "{projectName}-{version}",
    "version": {
      "preVersionCommand": "yarn dlx nx run-many -t build",
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "updateDependents": "never"
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "createRelease": "github",
        "file": "{projectRoot}/CHANGELOG.md"
      }
    },
    "git": {
      "commit": true,
      "tag": true,
      "push": true,
      "commitMessage": "chore({projectName}): release version {version} [skip ci]"
    },
    "conventionalCommits": {
      "types": {
        "feat": {
          "semverBump": "minor",
          "changelog": {
            "title": "Features"
          }
        },
        "fix": {
          "semverBump": "patch",
          "changelog": {
            "title": "Bug Fixes"
          }
        },
        "docs": {
          "semverBump": "patch",
          "changelog": {
            "title": "Documentation"
          }
        },
        "chore": {
          "semverBump": "patch",
          "changelog": {
            "title": "Chores"
          }
        },
        "refactor": {
          "semverBump": "patch",
          "changelog": {
            "title": "Refactors"
          }
        }
      }
    }
  }
}
